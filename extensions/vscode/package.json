{
  "name": "hermes-ilma",
  "displayName": "Hermes Agent Bridge",
  "description": "Hermes Coding Agent Platform Extension",
  "version": "1.0.0",
  "publisher": "hermes-local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:hermes.chatView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hermes.startSession",
        "title": "Hermes: Start Session"
      },
      {
        "command": "hermes.openSidebar",
        "title": "Hermes: Open Sidebar",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "hermes.configure",
        "title": "Hermes: Open Settings"
      }
    ],
    "keybindings": [
      {
        "command": "hermes.openSidebar",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hermes-sidebar",
          "title": "Hermes",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "hermes-sidebar": [
        {
          "type": "webview",
          "id": "hermes.chatView",
          "name": "Agent Chat"
        }
      ]
    },
    "configuration": {
      "title": "Hermes Agent Bridge",
      "properties": {
        "hermes.serverHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Hermes server IP address or hostname"
        },
        "hermes.serverPort": {
          "type": "number",
          "default": 3000,
          "description": "Hermes server port"
        },
        "hermes.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3000",
          "description": "Full Hermes server URL (overrides host/port if set manually)"
        },
        "hermes.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for Hermes server (if required)"
        },
        "hermes.profile": {
          "type": "string",
          "default": "ilma",
          "description": "Hermes agent profile name"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.1.3"
  }
}
